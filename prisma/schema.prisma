generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("admin")
  createdAt DateTime @default(now())
}

model Lead {
  id          String   @id @default(cuid())
  name        String
  email       String
  phone       String?
  location    String
  workers     String
  checkin     String?
  checkout    String?
  budget      String?
  sharedRooms String   @default("Yes")
  message     String?
  status      String   @default("new")
  source      String   @default("website")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Property {
  id            String   @id @default(cuid())
  title         String
  address       String
  city          String
  postcode      String
  bedrooms      Int
  bathrooms     Int
  maxGuests     Int
  type          String
  status        String   @default("active")
  amenities     String
  description   String
  pricePerNight Float?
  available     Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Booking {
  id         String   @id @default(cuid())
  propertyId String
  leadId     String?
  guestName  String
  guestEmail String
  checkin    DateTime
  checkout   DateTime
  workers    Int
  totalCost  Float?
  status     String   @default("confirmed")
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
